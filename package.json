{
  "name": "reportajgo-agent",
  "version": "0.1.0",
  "description": "AI agent that researches regional news, generates per-platform posts + media, and publishes to social media after human approval.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "start:app": "node dist/app.js",
    "start:worker": "node dist/worker.js",
    "start:bot": "node dist/bot.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-public.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker": "tsx src/worker.ts",
    "gen:images": "tsx src/scripts/gen-images.ts",
    "make:card": "tsx src/scripts/make-card.ts",
    "publish:check": "tsx src/scripts/publish-check.ts",
    "media:retry": "tsx src/scripts/media-retry.ts",
    "gen:images:prod": "node dist/scripts/gen-images.js",
    "make:card:prod": "node dist/scripts/make-card.js",
    "publish:check:prod": "node dist/scripts/publish-check.js",
    "media:retry:prod": "node dist/scripts/media-retry.js",
    "higgsfield:login": "tsx src/scripts/higgsfield-login.ts",
    "test:meta": "tsx src/scripts/test-meta.ts",
    "test:dop": "tsx src/scripts/test-dop.ts",
    "instagram:login": "tsx src/publish/instagramWeb/login.ts",
    "canva:login": "tsx src/generate/media/canva/login.ts",
    "canva:test": "tsx src/generate/media/canva/test.ts",
    "canva:probe": "tsx src/generate/media/canva/probe.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts"
  },
  "overrides": {
    "ioredis": "^5.4.2"
  },
  "dependencies": {
    "@google/genai": "^1.9.0",
    "@higgsfield/client": "^0.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/client": "^6.2.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.61.1",
    "telegraf": "^4.16.3",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
