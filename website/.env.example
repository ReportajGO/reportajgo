# Copy to .env and fill in. NEVER commit the real .env.

# Database (Postgres)
DATABASE_URL="postgresql://reportajgo:reportajgo@localhost:5434/reportajgo_frontend?schema=public"

# NextAuth — generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Admin account used by the DB seed (>=12 chars). Never use a default password.
ADMIN_EMAIL="admin@reportajgo.uz"
ADMIN_PASSWORD=""

# Translation / AI providers
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""
TILMOCH_API_KEY=""
GEMINI_API_KEY=""
GEMINI_MODEL=""

# ReportajGO AI agent — shared bearer token for POST /api/agent/posts.
# Must match WEBSITE_API_KEY in the agent project's .env.
AGENT_API_KEY=""

# Media uploads / agent image re-hosting
# local writes to public/uploads. s3 uploads to AWS S3 and stores public URLs.
UPLOAD_STORAGE_DRIVER="local"
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_ENDPOINT=""
AWS_S3_FORCE_PATH_STYLE="false"
AWS_S3_PUBLIC_BASE_URL=""
AWS_S3_KEY_PREFIX="uploads"
