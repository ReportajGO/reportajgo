// ReportajGO — Prisma schema
// PostgreSQL for production and Docker-based local development.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Editorial users (admin panel access).
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String // bcrypt hash
  role      String   @default("admin")
  createdAt DateTime @default(now())
  posts     Post[]
}

// News sections (themes). Driven by the agent's topic filters: each topic the
// operator adds becomes a Category here (synced via POST /api/agent/themes).
model Category {
  id    String @id @default(cuid())
  slug  String @unique
  // Localized display names as JSON: { "uz": "...", "ru": "...", "en": "..." }.
  // Falls back to the slug when a locale is missing.
  labels String?
  // Optional brand styling for cover tiles; deterministic fallback when null.
  color  String?
  word   String?
  // Nav ordering (mirrors the agent's topic order) and visibility. Removing a
  // topic filter sets active=false so the theme drops out of the nav.
  order  Int     @default(100)
  active Boolean @default(true)
  posts  Post[]

  @@index([active, order])
}

// A single-language news article.
model Post {
  id        String  @id @default(cuid())
  title     String
  excerpt   String
  body      String
  imageUrl  String?
  language  String // original/source language: "uz" | "ru" | "en"
  // Per-language translations as JSON: { "uz": {title,excerpt,body}, "ru":{…}, "en":{…} }.
  // Lets ONE post show on every locale, rendered in the reader's language.
  // Falls back to the base title/excerpt/body when a translation is missing.
  translations String?
  breaking  Boolean @default(false)
  published Boolean @default(true)
  views     Int     @default(0)
  // Cover aspect ratio chosen in admin: "16:9" | "1:1" | "4:5".
  aspect    String  @default("16:9")
  // Extra photos as a JSON array of URLs (gallery shown on the article page).
  gallery   String?

  // Provenance for agent-ingested posts (the ReportajGO AI agent cross-posts
  // here after a human approves the item in its Telegram bot).
  origin    String  @default("manual") // "manual" | "agent"
  source    String? // publisher name, e.g. "Reuters"
  sourceUrl String? // original article URL
  // Idempotency key (the agent's content hash) so retries don't double-post.
  dedupeKey String? @unique
  // Soft-delete: when set, the post is "cleared" — hidden everywhere public but
  // recoverable via admin Restore. Admin clear wins (the agent never un-clears).
  clearedAt DateTime?

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  author     User?    @relation(fields: [authorId], references: [id])
  authorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([language, categoryId])
  @@index([createdAt])
}

// A banner advertisement managed from the admin panel. Each ad targets one named
// on-page slot (see lib/adSlots.ts) and renders as an image that optionally links
// out. A slot shows its highest-priority published ad that is within its optional
// schedule window; when none qualifies, the slot renders nothing (no placeholder).
model Ad {
  id        String  @id @default(cuid())
  // Internal label shown only in the admin list (not on the public site).
  title     String
  // Which on-page placement this ad fills, e.g. "home-banner" (lib/adSlots.ts).
  slot      String
  // Creative image (uploaded to /uploads or an S3 URL). Required.
  imageUrl  String
  // Optional click-through URL. When set, the creative links out (new tab).
  linkUrl   String?
  // Live toggle. Only published ads (in-window) are shown to the public.
  published Boolean @default(false)
  // Priority when several ads target the same slot: lower shows first.
  order     Int     @default(100)
  // Optional flight window. null start = live now; null end = never expires.
  startsAt  DateTime?
  endsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slot, published, order])
}
