NODE_ENV=production
LOG_LEVEL=info

GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash

# ─── Image generation (the branded-card robot) ───────────────────────────────
# Match the working local setup: a Higgsfield photo (via MCP/OAuth, subscription
# wallet) composited into the branded card, rendered in-code with @napi-rs/canvas.
MEDIA_GENERATION_ENABLED=true
IMAGE_PROVIDER=higgsfield-mcp
HIGGSFIELD_IMAGE_MODEL=nano_banana_pro
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Higgsfield OAuth for a headless server. The .secrets/higgsfield-oauth.json token
# file is NOT baked into the GHCR image. Two ways to supply it (pick one):
#   (A) RECOMMENDED — mount the token file. docker-compose.production.yml bind-mounts
#       ./.secrets into backend-worker, so copy your local
#       .secrets/higgsfield-oauth.json to <deploy>/.secrets/ and leave the vars below blank.
#       This also lets refreshed/rotated tokens persist (same as localhost).
#   (B) Env-var fallback — copy these two values out of that JSON file:
#         clientId     -> HIGGSFIELD_CLIENT_ID
#         refreshToken -> HIGGSFIELD_REFRESH_TOKEN
HIGGSFIELD_CLIENT_ID=
HIGGSFIELD_REFRESH_TOKEN=

# Branded card renderer. template = in-code reproduction (fast, reliable, matches
# the sample). 1:1 so the Higgsfield photo fills the square card uncropped.
BRAND_CARD_ENABLED=true
BRAND_CARD_RATIO=1:1
CARD_RENDERER=template

# Media storage.
#  - "local": fine for TELEGRAM-only (generation + publishing share the worker
#    container, so the publisher uploads the file straight from disk).
#  - "s3": REQUIRED for WEBSITE covers and INSTAGRAM, because those images must be
#    fetched over public HTTP (the frontend fetches the cover; Meta/Instagram fetch
#    the image). Reuse the SAME bucket/keys the frontend already uses for uploads
#    (frontend.env AWS_* block) — just keep AWS_S3_KEY_PREFIX=media so the agent's
#    files stay separate from the site's "uploads/" prefix.
MEDIA_STORAGE_DRIVER=s3
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_KEY_PREFIX=media

CONTENT_LANGUAGES=uz,ru,en
RESEARCH_TOPICS=World news,Breaking international news,Global technology and business
RESEARCH_SOURCES=CNN,BBC,Reuters,Associated Press,Al Jazeera,The Guardian,Bloomberg
ENABLED_PLATFORMS=TELEGRAM,WEBSITE
AUTO_PUBLISH=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_APPROVAL_BOT_TOKEN=
APPROVERS=

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
DASHBOARD_PORT=3010
DASHBOARD_BIND=0.0.0.0

WEBSITE_API_URL=http://frontend:3000
WEBSITE_PUBLIC_URL=https://reportajgo.uz
# MUST be identical to the website's AGENT_API_KEY (frontend.env). This is the
# shared bearer token the site's /api/agent/posts ingest endpoint checks.
WEBSITE_API_KEY=

# Instagram publisher: "graph" = Meta Graph API; "web" = browser automation of
# instagram.com ("post like a human"). "web" needs a browser in the worker image
# + a logged-in .instagram-profile mounted in — see docker-compose.production.yml.
# Add INSTAGRAM to ENABLED_PLATFORMS above once that browser setup is in place.
INSTAGRAM_PUBLISHER=web

PUBLIC_BASE_URL=
BRAND_TELEGRAM_URL=
BRAND_INSTAGRAM_URL=
BRAND_YOUTUBE_URL=

WEBAPP_ENABLED=true
WEBAPP_PUBLIC_URL=https://reportajgo.uz/ru/admin
WEBAPP_PATH=/ru/admin
WEBAPP_MENU_TEXT=Admin Panel

RESEARCH_CRON=0 */2 * * *
RESEARCH_MAX_AGE_HOURS=24
MAX_ITEMS_PER_RUN=8
NEWS_RETENTION_HOURS=24
TZ=Asia/Tashkent
