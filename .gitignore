node_modules/
dist/
.env
.env.local
backend.env
frontend.env
bot.env
*.log
.DS_Store

# Generated media output dir (root only — NOT src/generate/media source code)
/media/
/storage/

# Prisma
prisma/*.db
prisma/*.db-journal

# Coverage / test output
coverage/

# OAuth tokens / secrets
.secrets/

# Claude Code local settings (may contain tokens / machine-specific config)
.claude/

# Build caches / Next.js (the bundled website)
*.tsbuildinfo
.next/
website/public/uploads/*
!website/public/uploads/.gitkeep

# cloudflared binary for Telegram Mini App tunnel
/bin/cloudflared
/bin/cloudflared.exe

# Canva automation (login session + debug dumps)
/.canva-profile/
/.canva-debug/

# Instagram web automation (login session + debug dumps)
/.instagram-profile/
/.instagram-debug/
# Timestamped backups of the logged-in profile + portable session cookies,
# made before switching Instagram accounts. Live credentials — never commit.
/.ig-backup-*/

# Source photos of the presenter, used only to train the Higgsfield Soul by hand.
# No code reads this folder (the card renderer uses brand/logo.png and
# brand/reference.png), and the trained Soul lives in Higgsfield — so these never
# need to be versioned or deployed. They are personal photos of a real person:
# keep them out of git history, where they would be permanent and readable by
# everyone with repo access.
/brand/for face/

# Throwaway POC / debug runner scripts (may contain inline tokens)
/_run*.mts
/_*.mts

# Throwaway sample renders at repo root
/sample-post.png
/telegram-card-final.png
/telegram-sample-post.png
