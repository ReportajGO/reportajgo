// ReportajGO Agent — data model
// Pipeline: NewsItem -> PostDraft (per platform) -> MediaAsset -> approval -> ScheduledPost -> published

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Research output ──────────────────────────────────────────────────────────
model NewsItem {
  id          String   @id @default(cuid())
  title       String
  summary     String   @db.Text
  rawContent  String?  @db.Text
  sourceUrl   String
  sourceName  String?
  language    String // detected/source language
  topic       String? // matched research topic
  publishedAt DateTime?
  fetchedAt   DateTime @default(now())

  // Dedupe key: normalized hash of title+url. Unique to drop repeats.
  contentHash String @unique

  // Ranking (filled by the filter stage)
  score       Float?
  relevance   Float?
  rankReasons String? @db.Text

  status NewsStatus @default(NEW)

  drafts PostDraft[]

  @@index([status])
  @@index([fetchedAt])
}

enum NewsStatus {
  NEW // just researched
  FILTERED_OUT // dropped by ranking
  SELECTED // chosen for content generation
  DRAFTED // drafts created
}

// ─── Per-platform post draft ────────────────────────────────────────────────
model PostDraft {
  id         String   @id @default(cuid())
  newsItem   NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  newsItemId String

  platform Platform
  language String
  style    String // e.g. "telegram-narrative", "instagram-punchy"
  headline String? // short themed headline overlaid on the news card
  body     String   @db.Text
  hashtags String[] @default([])

  status PostStatus @default(PENDING_MEDIA)

  // Approval audit
  approvedBy String?
  approvedAt DateTime?
  rejectedReason String?
  approvalSentAt DateTime? // when this draft was pushed to Telegram for review

  media         MediaAsset[]
  scheduledPost ScheduledPost?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([platform])
}

enum Platform {
  TELEGRAM
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  WEBSITE
  // Deprecated (kept so historical rows stay valid); not offered in the UI.
  X
  TIKTOK
}

enum PostStatus {
  PENDING_MEDIA // waiting on image/video generation
  PENDING_APPROVAL // media ready, awaiting human review
  APPROVED // human approved, ready to schedule
  SCHEDULED // queued for a publish time
  PUBLISHED // live
  REJECTED // human rejected
  FAILED // generation or publish error
}

// ─── Generated media ──────────────────────────────────────────────────────────
model MediaAsset {
  id      String    @id @default(cuid())
  draft   PostDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftId String

  type        MediaType
  provider    String // "higgsfield" | "fal" | ...
  aspectRatio String // "1:1" | "9:16" | "16:9"
  prompt      String    @db.Text
  url         String? // remote URL once generated
  localPath   String? // local cache path
  externalJobId String? // provider job id for polling
  status      MediaStatus @default(QUEUED)
  error       String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  QUEUED
  GENERATING
  READY
  FAILED
}

// ─── Scheduling + publish result ──────────────────────────────────────────────
model ScheduledPost {
  id      String    @id @default(cuid())
  draft   PostDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftId String    @unique

  platform    Platform
  scheduledAt DateTime
  status      ScheduleStatus @default(PENDING)

  // Publish result
  publishedAt    DateTime?
  externalPostId String? // id/url returned by the platform
  error          String?  @db.Text
  attempts       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
}

enum ScheduleStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

// ─── Runtime settings (control panel) ─────────────────────────────────────────
// Single-row overrides edited live from the control panel. Anything stored here
// takes precedence over the matching .env default. Value is JSON-encoded so a
// key can hold a string, number, or array. Secrets are never stored here.
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
