# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── Database (Postgres) ──────────────────────────────────────────────────────
# Host ports are 5433/6380 (see docker-compose.yml) to avoid clashing with other
# local Postgres/Redis instances. Inside Docker the containers still use 5432/6379.
DATABASE_URL=postgresql://reportajgo:reportajgo@localhost:5433/reportajgo?schema=public

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── Research: Google Gemini ──────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash

# ─── Image generation ─────────────────────────────────────────────────────────
# "higgsfield": use the Higgsfield Soul/DoP API (needs HIGGSFIELD_CREDENTIALS).
# "gemini": generate images with the Gemini image model, stored locally and
# served under /media. Higgsfield falls back to Gemini if credentials are absent.
IMAGE_PROVIDER=higgsfield
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Directory generated media is written to, and the base URL it's served from.
MEDIA_DIR=media
# Defaults to http://localhost:DASHBOARD_PORT. Set a public URL (tunnel/CDN)
# when publishing generated media to social platforms.
PUBLIC_BASE_URL=
# local writes generated media to MEDIA_DIR and serves it from /media.
# s3 uploads generated media to AWS S3 and returns public S3/CDN URLs.
MEDIA_STORAGE_DRIVER=local
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: custom S3-compatible endpoint. Leave blank for AWS S3.
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
# Optional CDN/public base. Defaults to the bucket URL when blank.
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_KEY_PREFIX=media

# ─── Media generation: Higgsfield (optional, for video / IMAGE_PROVIDER=higgsfield) ─
# Create API credentials at https://cloud.higgsfield.ai (dashboard > API).
# Format: "KEY_ID:KEY_SECRET" (a server process needs a key — the MCP login
# in your chat client is NOT usable by this long-running agent).
HIGGSFIELD_CREDENTIALS=
# ─── Presenter voice: ElevenLabs (for `npm run anchor:video`) ─────────────────
# The presenter's cloned voice lives in YOUR ElevenLabs account and is private
# to it, so this key is the only way to reach it. Create one at
# https://elevenlabs.io (Profile > API Keys).
ELEVENLABS_API_KEY=
# The cloned Uzbek presenter voice.
ELEVENLABS_VOICE_ID=xr8iiOGfCd6vvCgIh6EV
# eleven_v3 covers Uzbek; eleven_multilingual_v2 / turbo do not.
ELEVENLABS_MODEL_ID=eleven_v3

# Fallback provider if Higgsfield is unavailable: "none" | "fal" | "replicate"
MEDIA_FALLBACK_PROVIDER=none
FAL_API_KEY=
REPLICATE_API_TOKEN=

# ─── Content config ───────────────────────────────────────────────────────────
# Comma-separated. Primary language posts are generated in this/these.
CONTENT_LANGUAGES=uz,ru,en
# Topics to research worldwide (comma-separated keywords/queries)
RESEARCH_TOPICS=World news,Breaking international news,Global technology and business
# Reputable global outlets to prioritize during research (comma-separated).
RESEARCH_SOURCES=CNN,BBC,Reuters,Associated Press,Al Jazeera,The Guardian,Bloomberg
# Platforms to generate drafts for (comma-separated).
# Options: TELEGRAM,INSTAGRAM,FACEBOOK,YOUTUBE,WEBSITE
ENABLED_PLATFORMS=TELEGRAM

# ─── Publishers ───────────────────────────────────────────────────────────────
# Telegram (start here — no app review needed). Create a bot via @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel

# Meta (Instagram + Facebook) — fill once app review is approved
META_ACCESS_TOKEN=
META_IG_BUSINESS_ID=
META_FB_PAGE_ID=

# X / Twitter (paid API tier required to post)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ─── Dashboard / approval API ─────────────────────────────────────────────────
DASHBOARD_PORT=3010
# Network interface the dashboard binds to. Loopback (127.0.0.1) keeps the
# control API off the network. Only set 0.0.0.0 behind an authenticating proxy.
DASHBOARD_BIND=127.0.0.1
# Comma-separated **numeric Telegram user IDs** allowed to control the bot
# (approve/reject/publish/settings). NOT emails — the bot compares against the
# sender's numeric id. Find yours by messaging @userinfobot on Telegram.
# Example: APPROVERS=123456789,987654321
APPROVERS=
# HTTP Basic login for the web dashboard / API. REQUIRED in production (the app
# refuses to start an open dashboard when NODE_ENV=production). In dev it may be
# blank (dashboard runs open, loopback-only, with a startup warning).
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# Telegram approval bot — sends each ready post for Approve/Reject review.
# Create a bot via @BotFather. Leave blank to disable the approval bot.
TELEGRAM_APPROVAL_BOT_TOKEN=

# Telegram Mini App / approval admin. In production set WEBAPP_PUBLIC_URL to the
# public HTTPS admin URL so the bot does not need a cloudflared quick tunnel.
WEBAPP_ENABLED=true
WEBAPP_PUBLIC_URL=
WEBAPP_PATH=/ru/admin
WEBAPP_MENU_TEXT=Admin Panel

# ─── Scheduling ───────────────────────────────────────────────────────────────
# How often the research job runs (cron). Default: every 2 hours.
RESEARCH_CRON=0 */2 * * *
# Only research news from the last N hours. Daily channel = 24; older is stale.
RESEARCH_MAX_AGE_HOURS=24
# Max top-ranked news items drafted per run (caps approval-queue volume/cost).
MAX_ITEMS_PER_RUN=8
# Timezone for scheduling posts
TZ=Asia/Tashkent
